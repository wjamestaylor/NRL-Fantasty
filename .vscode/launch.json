{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "One Click: Start app + open browser",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3100",
      "webRoot": "${workspaceFolder}/frontend",
      "preLaunchTask": "App: Start (frontend + backend)"
    },
    {
      "name": "FastAPI: Debug backend",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/backend/.venv/bin/python",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/backend"
      },
      "justMyCode": true
    },
    {
      "name": "Next.js: Debug frontend",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev -- -p 3100",
      "cwd": "${workspaceFolder}/frontend",
      "serverReadyAction": {
        "pattern": "- Local:\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Frontend: Open in browser",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3100",
      "webRoot": "${workspaceFolder}/frontend"
    }
  ],
  "compounds": [
    {
      "name": "Full App: Debug and open",
      "configurations": [
        "FastAPI: Debug backend",
        "Next.js: Debug frontend"
      ],
      "stopAll": true
    }
  ]
}
